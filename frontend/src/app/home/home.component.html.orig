      <div class="carousel" (mouseenter)="stopAutoplay()" (mouseleave)="startAutoplay()">
        <div class="carousel-track">
          <img *ngFor="let img of images; let i = index"
               [src]="img"
               [class.active]="i === current"
               alt="Hotel image {{i + 1}}" />
        </div>

        <button class="carousel-control prev" (click)="prev()" aria-label="Previous image">‹</button>
        <button class="carousel-control next" (click)="next()" aria-label="Next image">›</button>

        <div class="carousel-indicators">
          <button *ngFor="let img of images; let i = index"
                  (click)="goTo(i)"
                  [class.active]="i === current"
                  [attr.aria-label]="'Go to image ' + (i + 1)">
          </button>
        </div>
      </div>
    </div>
    </div>
</section>
